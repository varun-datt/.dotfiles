{{- $workEnabled := index . "workEnabled" | default false -}}
{{- $configHome := .xdg.configHome -}}
{{- $c := .catppuccin.palette.mocha -}}
[user]
  name = {{ .name }}
  email = {{ .email }}
  signingkey = {{ .sshKey }}

[commit]
  gpgsign = true

[gpg]
  format = ssh

[gpg "ssh"]
  allowedSignersFile = {{ $configHome }}/git/allowed_signers

[alias]
  st = status
  cm = commit
  br = branch
  co = checkout
  df = diff
  dfc = diff --cached
  pr = pull --rebase
  pf = push --force-with-lease
  lg = log -p
  hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
  g = grep --break --heading --line-number
  bl = blame -w -C -C -C
  type = cat-file -t
  dump = cat-file -p
  gone = ! git fetch -p && git for-each-ref --format '%(refname:short) %(upstream:track)' | awk '$2 == \"[gone]\" {print $1}' | xargs -r git branch -D

[branch]
  sort = -committerdate

# Native git colors (status, branch, log --decorate, grep, etc.). Diffs use delta.
[color]
  ui = auto

[color "branch"]
  current = "{{ $c.green }}" bold
  local = "{{ $c.text }}"
  remote = "{{ $c.sapphire }}"
  upstream = "{{ $c.mauve }}"
  plain = "{{ $c.subtext0 }}"

[color "status"]
  header = "{{ $c.subtext0 }}"
  added = "{{ $c.green }}"
  updated = "{{ $c.green }}" bold
  changed = "{{ $c.yellow }}"
  untracked = "{{ $c.red }}"
  branch = "{{ $c.blue }}" bold
  nobranch = "{{ $c.peach }}" bold ul
  localBranch = "{{ $c.blue }}"
  remoteBranch = "{{ $c.sapphire }}"
  unmerged = "{{ $c.mauve }}" bold reverse

[color "diff"]
  meta = "{{ $c.overlay0 }}"
  frag = "{{ $c.mauve }}" bold
  func = "{{ $c.blue }}"
  context = "{{ $c.text }}"
  old = "{{ $c.red }}" bold
  new = "{{ $c.green }}" bold
  commit = "{{ $c.yellow }}"
  whitespace = "{{ $c.red }}" reverse
  oldMoved = "{{ $c.maroon }}"
  newMoved = "{{ $c.teal }}"

[color "decorate"]
  branch = "{{ $c.green }}" bold
  remoteBranch = "{{ $c.sapphire }}" bold
  tag = "{{ $c.yellow }}" bold
  stash = "{{ $c.mauve }}" bold
  HEAD = "{{ $c.blue }}" bold
  grafted = "{{ $c.overlay1 }}"

[color "grep"]
  filename = "{{ $c.mauve }}"
  function = "{{ $c.blue }}"
  lineNumber = "{{ $c.overlay0 }}"
  column = "{{ $c.overlay0 }}"
  match = "{{ $c.red }}" bold
  matchContext = "{{ $c.peach }}"
  matchSelected = "{{ $c.red }}" bold
  context = "{{ $c.subtext0 }}"
  selected = "{{ $c.text }}"
  separator = "{{ $c.overlay0 }}"

[color "interactive"]
  prompt = "{{ $c.blue }}"
  header = "{{ $c.text }}" bold
  help = "{{ $c.subtext0 }}"
  error = "{{ $c.red }}" bold

[color "blame"]
  highlightRecent = "{{ $c.overlay0 }},12 month ago,{{ $c.text }},1 month ago,{{ $c.red }}"
  repeatedLines = "{{ $c.overlay0 }}"

[color "advice"]
  hint = "{{ $c.sky }}"

[color "remote"]
  hint = "{{ $c.sky }}"
  warning = "{{ $c.yellow }}"
  success = "{{ $c.green }}"
  error = "{{ $c.red }}"

[color "push"]
  error = "{{ $c.red }}"

[color "transport"]
  rejected = "{{ $c.red }}"

[core]
  pager = delta
  excludesfile = {{ $configHome }}/git/ignore
  longpaths = true

[delta]
  navigate = true    # use n and N to move between diff sections
  features = catppuccin-mocha
  # Catppuccin needs the matching bat theme; the after-setup script builds it.
  syntax-theme = "Catppuccin Mocha"

# Catppuccin Mocha palette for delta diffs.
[include]
  path = {{ $configHome }}/delta/catppuccin.gitconfig

[init]
  defaultBranch = main

[column]
  ui = auto

[diff]
  colorMoved = default
  algorithm = histogram

[fetch]
  prune = true
  pruneTags = true

[grep]
  extendRegexp = true
  lineNumber = true

[help]
  autocorrect = 5

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictstyle = zdiff3

[pull]
  ff = only

[push]
  autoSetupRemote = true

[rebase]
  autoSquash = true
  autoStash = true

[rerere]
  enabled = true

[tag]
  sort = -version:refname

# gh handler
[credential "https://github.com"]
  helper =
  helper = !gh auth git-credential
  username = varun-datt

[credential "https://gist.github.com"]
  helper =
  helper = !gh auth git-credential
  username = varun-datt
{{ if eq .chezmoi.os "darwin" }}
[credential]
  helper =
  helper = git-credential-manager
[credential "https://dev.azure.com"]
  helper =
  helper = git-credential-manager
  useHttpPath = true
{{ end }}
{{ if $workEnabled }}
[includeIf "gitdir:{{ .work.sandboxWorkDir }}/**"]
  path = {{ .work.gitconfig }}
{{ end }}
