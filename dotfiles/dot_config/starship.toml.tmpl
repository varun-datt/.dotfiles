{{- $c := .catppuccin.palette.mocha -}}
"$schema" = 'https://starship.rs/config-schema.json'

palette = 'catppuccin_mocha'

[git_status]
ignore_submodules = true

[git_metrics]
ignore_submodules = true

[cmd_duration]
min_time = 2000
format = '\[[⏱ $duration]($style)\]'
style = 'yellow'

[directory]
style = 'blue'

[git_branch]
style = 'mauve'

# Surfaced because the kube/cloud context matters day-to-day here.
[kubernetes]
disabled = false
style = 'mauve'
{{- if eq .chezmoi.os "windows" }}
format = '[$symbol(\($namespace\))]($style) '
{{- else }}
format = '[$symbol$context( \($namespace\))]($style) '
{{- end }}

[aws]
style = 'peach'
symbol = ' '

[palettes.catppuccin_mocha]
rosewater = "{{ $c.rosewater }}"
flamingo = "{{ $c.flamingo }}"
pink = "{{ $c.pink }}"
mauve = "{{ $c.mauve }}"
red = "{{ $c.red }}"
maroon = "{{ $c.maroon }}"
peach = "{{ $c.peach }}"
yellow = "{{ $c.yellow }}"
green = "{{ $c.green }}"
teal = "{{ $c.teal }}"
sky = "{{ $c.sky }}"
sapphire = "{{ $c.sapphire }}"
blue = "{{ $c.blue }}"
lavender = "{{ $c.lavender }}"
text = "{{ $c.text }}"
subtext1 = "{{ $c.subtext1 }}"
subtext0 = "{{ $c.subtext0 }}"
overlay2 = "{{ $c.overlay2 }}"
overlay1 = "{{ $c.overlay1 }}"
overlay0 = "{{ $c.overlay0 }}"
surface2 = "{{ $c.surface2 }}"
surface1 = "{{ $c.surface1 }}"
surface0 = "{{ $c.surface0 }}"
base = "{{ $c.base }}"
mantle = "{{ $c.mantle }}"
crust = "{{ $c.crust }}"
