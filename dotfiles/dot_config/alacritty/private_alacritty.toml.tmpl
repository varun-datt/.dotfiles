{{- $c := .catppuccin.palette.mocha -}}
[env]
TERM = "xterm-256color"

[font]
size = 14.0

[font.normal]
family = "JetBrainsMono Nerd Font"
style = "Regular"

[scrolling]
history = 5000

[terminal]

[terminal.shell]
args = ["new", "-A", "-s", "main"]
program = "/usr/bin/tmux"

# Catppuccin Mocha (colors from .chezmoidata/catppuccin.yaml)
[colors.primary]
background = "{{ $c.base }}"
foreground = "{{ $c.text }}"
dim_foreground = "{{ $c.overlay1 }}"
bright_foreground = "{{ $c.text }}"

[colors.cursor]
text = "{{ $c.base }}"
cursor = "{{ $c.rosewater }}"

[colors.vi_mode_cursor]
text = "{{ $c.base }}"
cursor = "{{ $c.lavender }}"

[colors.search.matches]
foreground = "{{ $c.base }}"
background = "{{ $c.subtext0 }}"

[colors.search.focused_match]
foreground = "{{ $c.base }}"
background = "{{ $c.green }}"

[colors.footer_bar]
foreground = "{{ $c.base }}"
background = "{{ $c.subtext0 }}"

[colors.hints.start]
foreground = "{{ $c.base }}"
background = "{{ $c.yellow }}"

[colors.hints.end]
foreground = "{{ $c.base }}"
background = "{{ $c.subtext0 }}"

[colors.selection]
text = "{{ $c.base }}"
background = "{{ $c.rosewater }}"

[colors.normal]
black = "{{ $c.surface1 }}"
red = "{{ $c.red }}"
green = "{{ $c.green }}"
yellow = "{{ $c.yellow }}"
blue = "{{ $c.blue }}"
magenta = "{{ $c.pink }}"
cyan = "{{ $c.teal }}"
white = "{{ $c.subtext1 }}"

[colors.bright]
black = "{{ $c.surface2 }}"
red = "{{ $c.red }}"
green = "{{ $c.green }}"
yellow = "{{ $c.yellow }}"
blue = "{{ $c.blue }}"
magenta = "{{ $c.pink }}"
cyan = "{{ $c.teal }}"
white = "{{ $c.subtext0 }}"
