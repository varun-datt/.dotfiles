{{ if ne .chezmoi.os "windows" -}}
{{- $workEnabled := index . "workEnabled" | default false -}}
#!/bin/bash

set -e

mkdir -p "$HOME/sandbox"

# Tmux Plugin Manager
_config_home="{{ .xdg.configHome | replace "~" "$HOME" }}"
_tmux_plugins_directory="$_config_home/tmux/plugins/tpm"
if [ ! -d "$_tmux_plugins_directory" ]; then
  git clone https://github.com/tmux-plugins/tpm "$_tmux_plugins_directory"
fi

if command -v tmux >/dev/null 2>&1 && [ -x "$_tmux_plugins_directory/bin/install_plugins" ]; then
  "$_tmux_plugins_directory/bin/install_plugins" || echo "Warning: TPM plugin auto-install failed"
fi

# Fish shell
_fish_path="$(command -v fish)"
if [ -n "$_fish_path" ] && [ "$SHELL" != "$_fish_path" ]; then
  if ! grep -qxF "$_fish_path" /etc/shells; then
    echo "$_fish_path" | sudo tee -a /etc/shells >/dev/null
  fi
  chsh -s "$_fish_path"
fi

{{ $fisherfilePath := "dot_config/private_fish/fish_plugins" }}
echo "hash: {{ include $fisherfilePath | sha256sum }}"
fish -c "fisher update"

# Tools via mise (~/.config/mise/config.toml)
echo "hash: {{ include "dot_config/mise/config.toml" | sha256sum }}"
if command -v mise >/dev/null 2>&1; then
  mise install -y
fi

# bat Catppuccin Mocha theme
if command -v bat >/dev/null 2>&1; then
  _bat_themes_dir="$(bat --config-dir)/themes"
  if [ ! -f "$_bat_themes_dir/Catppuccin Mocha.tmTheme" ]; then
    mkdir -p "$_bat_themes_dir"
    curl -fsSL -o "$_bat_themes_dir/Catppuccin Mocha.tmTheme" \
      "https://github.com/catppuccin/bat/raw/main/themes/Catppuccin%20Mocha.tmTheme"
    bat cache --build
  fi
fi

# yazi Catppuccin flavors
if command -v ya >/dev/null 2>&1; then
  ya pkg add yazi-rs/flavors:catppuccin-mocha || true
fi

# SSH
_generate_ssh_key() {
  local _key="$1"
  local _comment="$2"
  if [ ! -f "$_key" ]; then
    mkdir -p "$HOME/.ssh"
    ssh-keygen -t ed25519 -C "$_comment" -f "$_key" -N ""
    echo "SSH public key ($_comment — add to your Git host):"
    cat "${_key}.pub"
  fi
}

_generate_ssh_key "{{ .sshKey | replace "~" "$HOME" }}" "$(hostname)"

{{ if $workEnabled -}}
mkdir -p "{{ .work.sandboxWorkDir | replace "~" "$HOME" }}"
_generate_ssh_key "{{ .work.sshKey | replace "~" "$HOME" }}" "$(hostname)"
{{ end -}}

{{ end -}}
